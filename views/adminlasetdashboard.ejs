<!-- Optional JavaScript for form validation -->
<script>
  // Client-side form validation before submission
  document.addEventListener('DOMContentLoaded', function() {
    const materialForm = document.querySelector('#materialForm');
    
    if (materialForm) {
      materialForm.addEventListener('submit', function(event) {
        const materialName = document.querySelector('input[name="mname"]');
        
        // Basic validation
        if (!materialName.value.trim()) {
          event.preventDefault();
          materialName.classList.add('is-invalid');
          materialName.scrollIntoView({ behavior: 'smooth', block: 'center' });
          return false;
        } else {
          materialName.classList.remove('is-invalid');
        }
        
        // Optional: Check for duplicate material names (you would need an API endpoint)
        // You can uncomment and implement this if needed
        /*
        fetch('/check_material_exists', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ mname: materialName.value.trim() })
        })
        .then(response => response.json())
        .then(data => {
          if (data.exists) {
            event.preventDefault();
            materialName.classList.add('is-invalid');
            materialName.setCustomValidity('Material already exists');
            // Show custom error message
          }
        });
        */
      });
      
      // Clear validation on input
      document.querySelector('input[name="mname"]').addEventListener('input', function() {
        this.classList.remove('is-invalid');
        this.setCustomValidity('');
      });
    }
  });
  
  // Optional: Reset form when modal is closed
  $('#materialModal').on('hidden.bs.modal', function () {
    const form = document.querySelector('#materialForm');
    if (form) {
      form.reset();
      form.querySelectorAll('.is-invalid').forEach(el => {
        el.classList.remove('is-invalid');
      });
    }
  });
</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
