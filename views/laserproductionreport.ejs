<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes, maximum-scale=1.5">
  <title>Production Entry | Offcuts Material System</title>

  <!-- Bootstrap 5 & Icons -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      background: linear-gradient(135deg, #f5f7fa 0%, #e9ecef 100%);
      font-family: 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif;
      min-height: 100vh;
      padding: 0;
    }

    .navbar {
      background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
      box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2);
      padding: 0.75rem 1rem;
      margin-bottom: 1.5rem;
    }

    .navbar-brand {
      font-weight: 700;
      font-size: 1.4rem;
      letter-spacing: 0.5px;
      color: white !important;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .navbar-brand i {
      font-size: 1.6rem;
      color: #ffd966;
    }

    .navbar-nav .nav-link {
      color: rgba(255, 255, 255, 0.9) !important;
      font-weight: 500;
      margin: 0 0.2rem;
      padding: 0.5rem 1rem !important;
      border-radius: 30px;
      transition: all 0.25s ease;
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 0.95rem;
    }

    .navbar-nav .nav-link i {
      font-size: 1rem;
      color: #ffd966;
    }

    .navbar-nav .nav-link:hover {
      background: rgba(255, 255, 255, 0.15);
      color: white !important;
      transform: translateY(-1px);
    }

    .navbar-nav .nav-link.active {
      background: rgba(255, 255, 255, 0.2);
      color: white !important;
      font-weight: 600;
      box-shadow: 0 2px 8px rgba(0,0,0,0.15);
    }

    .navbar-toggler {
      border: none;
      color: white;
      font-size: 1.5rem;
      padding: 0.4rem 0.7rem;
      background: rgba(255,255,255,0.15);
      border-radius: 10px;
    }

    .container {
      max-width: 1400px;
      padding-left: 12px;
      padding-right: 12px;
    }

    .card {
      border: none;
      border-radius: 20px;
      box-shadow: 0 20px 35px -12px rgba(0, 0, 0, 0.15);
      overflow: hidden;
      transition: transform 0.2s ease;
    }

    .card:hover {
      transform: translateY(-2px);
    }

    .card-header {
      background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
      border-bottom: none;
      padding: 1rem 1.25rem;
    }

    .card-header h4 {
      font-weight: 600;
      letter-spacing: 0.3px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 12px;
      margin: 0;
      font-size: 1.1rem;
      color: white;
    }

    .card-header h4 i {
      margin-right: 8px;
      font-size: 1.2rem;
    }

    .card-body {
      padding: 1.5rem;
      background: white;
    }

    .form-label {
      font-weight: 600;
      font-size: 0.75rem;
      margin-bottom: 0.4rem;
      color: #2c3e66;
      letter-spacing: 0.5px;
      text-transform: uppercase;
    }

    .form-control,
    .form-select {
      border-radius: 10px;
      border: 1.5px solid #e2e8f0;
      padding: 0.5rem 0.85rem;
      font-size: 0.9rem;
      transition: all 0.2s ease;
      background-color: #fefefe;
    }

    .form-control:focus,
    .form-select:focus {
      border-color: #2a5298;
      box-shadow: 0 0 0 3px rgba(42, 82, 152, 0.15);
      outline: none;
    }

    .form-control[readonly] {
      background-color: #f8f9fc;
      font-weight: 500;
      color: #1e3c72;
    }

    .required {
      color: #dc3545;
      font-weight: 700;
      margin-left: 3px;
    }

    hr {
      margin: 1.2rem 0;
      border: 0;
      height: 2px;
      background: linear-gradient(90deg, transparent, #2a5298, #1e3c72, transparent);
      opacity: 0.3;
    }

    .btn-success {
      background: linear-gradient(135deg, #28a745 0%, #218838 100%);
      border: none;
      border-radius: 40px;
      padding: 0.6rem 1.5rem;
      font-weight: 600;
      font-size: 0.9rem;
      transition: all 0.2s;
      box-shadow: 0 3px 8px rgba(40, 167, 69, 0.25);
    }

    .btn-success:hover {
      transform: translateY(-1px);
      box-shadow: 0 5px 12px rgba(40, 167, 69, 0.35);
    }

    .btn-secondary {
      border-radius: 40px;
      padding: 0.6rem 1.5rem;
      font-size: 0.9rem;
    }

    .btn-sm {
      border-radius: 40px;
      font-weight: 500;
      padding: 0.35rem 1rem;
      font-size: 0.75rem;
    }

    .badge-soft {
      background: #eef2ff;
      color: #1e3c72;
      border-radius: 30px;
      padding: 4px 10px;
      font-size: 0.65rem;
    }

    .text-muted-info {
      font-size: 0.7rem;
      color: #6c8dae;
      margin-top: 5px;
      display: inline-block;
    }

    @media (max-width: 768px) {
      .card-header h4 {
        flex-direction: column;
        align-items: stretch;
        text-align: center;
      }
      .btn-success, .btn-secondary {
        width: 100%;
      }
    }

    @media (max-width: 576px) {
      .card-body {
        padding: 1rem;
      }
      .form-control, .form-select {
        font-size: 0.85rem;
      }
    }

    .reset-notice {
      background: #eef2ff;
      border-left: 4px solid #2a5298;
      font-size: 0.7rem;
      padding: 4px 12px;
      border-radius: 20px;
      display: inline-block;
    }
  </style>
</head>
<body>

  <nav class="navbar navbar-expand-lg">
    <div class="container-fluid">
      <a class="navbar-brand" href="/">
        <i class="fas fa-industry"></i> NeatWind
      </a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarLinks" 
              aria-controls="navbarLinks" aria-expanded="false" aria-label="Toggle navigation">
        <i class="fas fa-bars"></i>
      </button>
      <div class="collapse navbar-collapse" id="navbarLinks">
        <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
          <li class="nav-item">
            <a class="nav-link active" href="#"><i class="fas fa-plus-circle"></i> New Entry</a>
          </li>
          <li class="nav-item">
            <% if(operator[0].role == "admin"){ %>
              <a class="nav-link" href="/adminlasetdashboard"><i class="fas fa-chart-line"></i> Records Dashboard</a>
            <% }else{ %>
              <a class="nav-link" href="/laserproductionrecord"><i class="fas fa-chart-line"></i> Records Dashboard</a>
            <% } %>
          </li>

          <li class="nav-item">
            <a class="nav-link" href="/logoutuser"><i class="fas fa-sign-out-alt"></i> Logout</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <div class="container py-3 py-md-4">
    <div class="card">
      <% if(operator[0].role == "admin"){ %>
        <div class="card-header bg-primary text-white">
          <h4 class="mb-0">
            <i class="fas fa-cube me-2"></i>Laser Daily Entry Form
            <a href="/adminlasetdashboard" style="text-decoration: none;">
              <button class="btn btn-success btn-sm" type="button">
              <i class="fas fa-chart-simple me-1"></i> Production & Downtime Records
              </button>
            </a>
          </h4>
        </div>
      <% }else{ %>
        <div class="card-header bg-primary text-white">
          <h4 class="mb-0">
            <i class="fas fa-cube me-2"></i>Laser Daily Entry Form
            <a href="/laserproductionrecord" style="text-decoration: none;">
              <button class="btn btn-success btn-sm" type="button">
              <i class="fas fa-chart-simple me-1"></i> Production & Downtime Records
              </button>
            </a>
          </h4>
        </div>
      <% } %>

      <div class="card-body">
        <form method="post" action="/save_details" id="productionForm">
          <div class="row g-3 g-md-4">
            <div class="col-12 col-sm-6 col-md-4">
              <label class="form-label"><i class="far fa-calendar-alt me-1"></i> Timestamp <span class="required">*</span></label>
              <input type="date" class="form-control" name="g_date" id="g_date" required>
            </div>

            <div class="col-12 col-sm-6 col-md-4">
              <label class="form-label"><i class="fas fa-user-circle me-1"></i> Operator Name</label>
              <input type="text" name="g_operator_name" class="form-control" id="operatorSelect" value="<%= operator[0].oname %>" readonly>
            </div>

            <div class="col-12 col-sm-6 col-md-4">
              <label class="form-label"><i class="fas fa-clock me-1"></i> Shift</label>
              <select class="form-select" name="g_shift">
                <option value="">-- Select Shift --</option>
                <option value="1st">1st</option>
                <option value="2nd">2nd</option>
                <option value="3rd">3rd</option>
              </select>
            </div>

            <div class="col-12 col-md-4">
                <label class="form-label">
                    <i class="fas fa-building me-1"></i> Customer Name
                    <span class="required">*</span>
                </label>
                <select name="g_customer" id="customerSelect" class="form-select" required>
                    <option value="">-- Select Customer --</option>
                    <% for(let i=0; i<customer.length; i++){ %>
                        <option value="<%= customer[i].cname %>">
                            <%= customer[i].cname %>
                        </option>
                    <% } %>
                </select>
            </div>

            <div class="col-12 col-md-4">
              <label class="form-label"><i class="fas fa-diagram-project me-1"></i> Project Name <span class="required">*</span></label>
              <select name="g_project_name" id="projectSelect" class="form-select" required>
                  <option value="">-- Select Project --</option>
              </select>
            </div>

            <div class="col-12 col-sm-6 col-md-4">
              <label class="form-label"><i class="fas fa-layer-group me-1"></i> Set</label>
              <select name="g_set_name" id="setSelect" class="form-select">
                <option value="">-- Select Set --</option>
                <% for(let i = 0; i < 200 ; i++) { %>
                        <option value="<%= i + 1 %>">
                            <%= i+1 %>
                        </option>
                <% } %>
              </select>
            </div>

            <div class="col-12 col-sm-6 col-md-4">
              <label class="form-label"><i class="fas fa-database me-1"></i> Material <span class="required">*</span></label>
              <select name="g_material" id="materialSelect" class="form-select" required>
                <option value="">-- Select Material --</option>
                <% for(let i = 0; i < material.length; i++) { %>
                        <option value="<%= material[i].mname %>">
                            <%= material[i].mname %>
                        </option>
                    <% } %>
              </select>
            </div>

            <div class="col-12 col-sm-6 col-md-4">
              <label class="form-label"><i class="fas fa-hashtag me-1"></i> Sheet Qty</label>
              <select id="qty" class="form-select calculate" name="g_sheetqty">
                    <option value="">-- Select Sheet Quantity --</option>
                        <% for(let i = 0; i < 100 ; i++) { %>
                            <option value="<%= i + 1 %>">
                                <%= i+1 %>
                            </option>
                        <% } %>
              </select>
            </div>
            <div class="col-12 col-sm-6 col-md-4">
              <label class="form-label"><i class="fas fa-arrows-left-right me-1"></i> Length (mm)</label>
              <input type="number" step="0.01" id="length" class="form-control calculate" name="g_length" placeholder="mm">
            </div>
            <div class="col-12 col-sm-6 col-md-4">
              <label class="form-label"><i class="fas fa-arrows-up-down me-1"></i> Width (mm)</label>
              <input type="number" step="0.01" id="width" class="form-control calculate" name="g_width" placeholder="mm">
            </div>
            <div class="col-12 col-sm-6 col-md-4">
              <label class="form-label"><i class="fas fa-chart-line me-1"></i> Thickness (mm)</label>
              <input type="number" step="0.01" id="thickness" class="form-control calculate" name="g_thickness" placeholder="mm">
            </div>
            <div class="col-12 col-md-4">
              <label class="form-label"><i class="fas fa-weight-hanging me-1"></i> Total Weight (Kg)</label>
              <input type="text" id="totalWeight" class="form-control bg-light" readonly name="g_totalweight" placeholder="Auto calculated (density-based)">
            </div>
            <div class="col-12 col-md-4">
              <label class="form-label"><i class="fas fa-hourglass-half me-1"></i> Machine Start Time (HH:MM)</label>
              <input type="time" class="form-control" id="startTime" step="60" name="g_start_time">
            </div>
            <div class="col-12 col-md-4">
              <label class="form-label"><i class="fas fa-hourglass-half me-1"></i> Machine End Time (HH:MM)</label>
              <input type="time" class="form-control" id="endTime" step="60" name="g_end_time">
            </div>
            <div class="col-12 col-md-4">
              <label class="form-label"><i class="fas fa-hourglass-half me-1"></i> Process Time (HH:MM)</label>
              <input type="text" class="form-control bg-light" id="processTimeDisplay" readonly placeholder="Auto calculated (HH:MM)">
              <input type="hidden" id="processTimeHidden" name="g_process_time">
            </div>

            <div class="col-12"><hr></div>

            <div class="col-12 col-md-6">
              <label class="form-label"><i class="fas fa-tools me-1"></i> Machine Undermaintenance Time (min)</label>
              <input type="time" class="form-control" name="g_m_processtime" placeholder="eg 2:30 Min">
            </div>
            <div class="col-12 col-md-6">
              <label class="form-label"><i class="fas fa-exclamation-triangle me-1"></i> Machine Undermaintenance Reason</label>
              <select class="form-select" id="mureasonSelect" name="g_mureason">
                <option value="">-- Select Reason --</option>
                <option value="Mechanical Issue">🔧 Mechanical Issue</option>
                <option value="Electrical fault">⚡ Electrical fault</option>
                <option value="Material Shortage">📦 Material Shortage</option>
                <option value="Power Interruption">🔌 Power Interruption</option>
                <option value="Sanctioned Break">☕ Sanctioned Break</option>
                <option value="Line Changeover">🔄 Line Changeover</option>
                <option value="Other/Unclassified">❓ Other/Unclassified</option>
              </select>
              <div id="otherReasonDiv" style="display: none; margin-top: 10px;">
                <input type="text" class="form-control" name="other_gmr" id="otherReasonInput" placeholder="Please specify the reason..." value="">
                <small class="text-muted-info"><i class="fas fa-info-circle"></i> Please provide details</small>
              </div>
            </div>
            <div class="col-12 col-md-6">
              <label class="form-label"><i class="fas fa-clipboard-list me-1"></i> Justification & Corrective Action</label>
              <input type="text" class="form-control" name="g_mjustification" placeholder="Describe actions taken">
            </div>
            <div class="col-12 col-md-6">
              <label class="form-label"><i class="fas fa-times-circle me-1"></i> Rejection Quantity</label>
              <input type="text" class="form-control" name="g_rejectionqty" placeholder="Number of rejected parts">
            </div>

            <div class="col-12">
              <div class="d-flex flex-column flex-sm-row justify-content-end gap-3 mt-3">
                <button type="reset" class="btn btn-secondary px-4 py-2 order-2 order-sm-1"><i class="fas fa-undo-alt me-1"></i> Reset</button>
                <button type="submit" onclick="return confirmSubmit()" class="btn btn-success px-5 py-2 order-1 order-sm-2"><i class="fas fa-save me-2"></i> Save Record</button>
              </div>
            </div>
          </div>
        </form>
      </div>
      <div class="card-footer bg-white border-0 text-center pb-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
        <span class="badge-soft"><i class="fas fa-chart-line"></i> Material Density (g/cm³): MS=7.85, ALUMINIUM=2.70, SS=7.93, GI=7.85, HRPO=7.85, PERFORATED=7.85 | Weight = L×W×Th×Qty × (Density/1000) kg</span>
        <span class="reset-notice"><i class="fas fa-sync-alt"></i> Session data only — no local storage</span>
      </div>
    </div>
  </div>

<!-- Professional Operator Modal -->
<div class="modal fade" id="operatorModal" tabindex="-1" aria-labelledby="operatorModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border-0 shadow-lg rounded-4">
      
      <!-- Modern Header with accent -->
      <div class="modal-header border-0 pt-4 px-4">
        <div class="d-flex align-items-center gap-2">
          <div class="bg-primary bg-opacity-10 p-2 rounded-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="bi bi-person-plus text-primary" viewBox="0 0 16 16">
              <path d="M6 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6zm2-3a2 2 0 1 1-4 0 2 2 0 0 1 4 0zm4 8c0 1-1 1-1 1H1s-1 0-1-1 1-4 6-4 6 3 6 4zm-1-.004c-.001-.246-.154-.986-.832-1.664C9.516 10.68 8.289 10 6 10c-2.29 0-3.516.68-4.168 1.332-.678.678-.83 1.418-.832 1.664h10z"/>
              <path fill-rule="evenodd" d="M13.5 5a.5.5 0 0 1 .5.5V7h1.5a.5.5 0 0 1 0 1H14v1.5a.5.5 0 0 1-1 0V8h-1.5a.5.5 0 0 1 0-1H13V5.5a.5.5 0 0 1 .5-.5z"/>
            </svg>
          </div>
          <h5 class="modal-title fw-semibold" id="operatorModalLabel">Add New Operator</h5>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>

      <!-- Form Body with clean spacing -->
      <div class="modal-body px-4 pb-4">
        <form action="/save_operator" method="post" id="operatorForm">
          
          <!-- Department Dropdown -->
          <div class="mb-4">
            <label class="form-label fw-semibold small text-secondary mb-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="bi bi-building me-1" viewBox="0 0 16 16">
                <path d="M2 1a1 1 0 0 1 1-1h10a1 1 0 0 1 1 1v14a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V1zm11 0H3v14h3v-2.5a.5.5 0 0 1 .5-.5h3a.5.5 0 0 1 .5.5V15h3V1z"/>
              </svg>
              Department
            </label>
            <select name="deptname" class="form-select border-1 bg-light rounded-3 py-2" required>
              <option value="">-- Select Department --</option>
              <option value="Daily Production Reports">Daily Production Reports</option>
              <option value="Punching Department">Punching Department</option>
              <option value="Programming Department">Programming Department</option>
              <option value="Operating Department">Operating Department</option>
              <option value="Welding Department">Welding Department</option>
              <option value="Coating & Binding">Coating & Binding</option>
            </select>
            <div class="invalid-feedback">Please select a department.</div>
          </div>

          <!-- Operator Name Input -->
          <div class="mb-4">
            <label class="form-label fw-semibold small text-secondary mb-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="bi bi-person-badge me-1" viewBox="0 0 16 16">
                <path d="M6.5 2a.5.5 0 0 0 0 1h3a.5.5 0 0 0 0-1h-3zM11 8a3 3 0 1 1-6 0 3 3 0 0 1 6 0z"/>
                <path d="M4.5 0A2.5 2.5 0 0 0 2 2.5V14a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2V2.5A2.5 2.5 0 0 0 11.5 0h-7zM3 2.5A1.5 1.5 0 0 1 4.5 1h7A1.5 1.5 0 0 1 13 2.5v10.795a4.2 4.2 0 0 0-.776-.492C11.392 12.387 10.063 12 8 12s-3.392.387-4.224.803a4.2 4.2 0 0 0-.776.492V2.5z"/>
              </svg>
              Operator Name
            </label>
            <input type="text" name="oname" class="form-control border-1 bg-light rounded-3 py-2" placeholder="e.g., John Carter" required>
            <div class="invalid-feedback">Operator name is required.</div>
          </div>

          <!-- Action Buttons -->
          <div class="d-flex justify-content-end gap-2 mt-4 pt-2">
            <button type="button" class="btn btn-outline-secondary px-4 py-2 rounded-3" data-bs-dismiss="modal">
              Cancel
            </button>
            <button type="submit" class="btn btn-primary px-4 py-2 rounded-3 shadow-sm">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-check2-circle me-1" viewBox="0 0 16 16">
                <path d="M2.5 8a5.5 5.5 0 0 1 8.25-4.764.5.5 0 0 0 .5-.866A6.5 6.5 0 1 0 14.5 8a.5.5 0 0 0-1 0 5.5 5.5 0 1 1-11 0z"/>
                <path d="M15.354 3.354a.5.5 0 0 0-.708-.708L8 9.293 5.354 6.646a.5.5 0 1 0-.708.708l3 3a.5.5 0 0 0 .708 0l7-7z"/>
              </svg>
              Save Operator
            </button>
          </div>

        </form>
      </div>

    </div>
  </div>
</div>

<!-- Optional: Add custom responsive touches (no extra CSS needed if using Bootstrap 5) -->
<style>
  /* Smooth focus effects */
  .form-control:focus, .form-select:focus {
    border-color: #86b7fe;
    box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.15);
    background-color: #fff;
  }
  
  /* Responsive padding adjustments for mobile */
  @media (max-width: 576px) {
    .modal-body {
      padding: 1rem !important;
    }
    .btn {
      padding-left: 1rem !important;
      padding-right: 1rem !important;
    }
  }
  
  /* Subtle card hover effect */
  .modal-content {
    transition: transform 0.2s ease;
  }
  
  /* Better button spacing on small screens */
  @media (max-width: 400px) {
    .d-flex.justify-content-end {
      flex-direction: column-reverse;
      gap: 0.5rem !important;
    }
    .d-flex.justify-content-end .btn {
      width: 100%;
    }
  }
</style>

<!-- Professional Customer Modal -->
<div class="modal fade" id="customerModal" tabindex="-1" aria-labelledby="customerModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border-0 shadow-lg rounded-4">
      
      <!-- Modern Header with accent -->
      <div class="modal-header border-0 pt-4 px-4">
        <div class="d-flex align-items-center gap-2">
          <div class="bg-primary bg-opacity-10 p-2 rounded-3">
