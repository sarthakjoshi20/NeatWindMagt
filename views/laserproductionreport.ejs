  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

  <script>
    // Density mapping (g/cm³)
    const materialDensity = {
      "MS": 7.85,
      "ALUMINIUM": 2.70,
      "SS": 7.93,
      "GI": 7.85,
      "HRPO": 7.85,
      "PERFORATED": 7.85
    };

    // Material density-based weight calculation
    function calculateWeight() {
      let L = parseFloat(document.getElementById('length').value) || 0;
      let W = parseFloat(document.getElementById('width').value) || 0;
      let T = parseFloat(document.getElementById('thickness').value) || 0;
      let Q = parseFloat(document.getElementById('qty').value) || 0;
      let selectedMaterial = document.getElementById('materialSelect').value;
      let density = materialDensity[selectedMaterial] || 7.85;
      let weight = (L * W * T * Q * density) / 1000000;
      if (isNaN(weight) || weight <= 0) weight = 0;
      document.getElementById('totalWeight').value = weight.toFixed(3) + " Kg";
    }

    // Process time calculation (HH:MM) from start & end times
    function calculateProcessTime() {
      const start = document.getElementById('startTime').value;
      const end = document.getElementById('endTime').value;
      if (!start || !end) {
        document.getElementById('processTimeDisplay').value = '';
        document.getElementById('processTimeHidden').value = '';
        return;
      }
      const [startHour, startMin] = start.split(':').map(Number);
      const [endHour, endMin] = end.split(':').map(Number);
      let startTotal = startHour * 60 + startMin;
      let endTotal = endHour * 60 + endMin;
      let diffMinutes = endTotal - startTotal;
      if (diffMinutes < 0) diffMinutes += 24 * 60;
      const hours = Math.floor(diffMinutes / 60);
      const minutes = diffMinutes % 60;
      const formatted = `${hours.toString().padStart(2,'0')}:${minutes.toString().padStart(2,'0')}`;
      document.getElementById('processTimeDisplay').value = formatted;
      document.getElementById('processTimeHidden').value = formatted;
    }

    // Dynamic project loading based on selected customer
    document.getElementById("customerSelect").addEventListener("change", async function () {
      let customer = this.value;
      let projectSelect = document.getElementById("projectSelect");

      if (!customer) {
        projectSelect.innerHTML = '<option value="">-- Select Project --</option>';
        return;
      }

      projectSelect.innerHTML = '<option value="">Loading...</option>';

      try {
        let response = await fetch(`/get_projects/${customer}`);
        let projects = await response.json();
        projectSelect.innerHTML = '<option value="">-- Select Project --</option>';
        projects.forEach(project => {
          projectSelect.innerHTML += `<option value="${project.pname}">${project.pname}</option>`;
        });
      } catch(e) {
        projectSelect.innerHTML = '<option value="">-- Error loading projects --</option>';
      }
    });

    // Other reason logic (fixed: using "Other/Unclassified" value)
    const mureasonSelect = document.getElementById('mureasonSelect');
    const otherReasonDiv = document.getElementById('otherReasonDiv');
    const otherReasonInput = document.getElementById('otherReasonInput');
    
    if (mureasonSelect) {
      mureasonSelect.addEventListener('change', function() {
        if (mureasonSelect.value === 'Other/Unclassified') { 
          otherReasonDiv.style.display = 'block'; 
          otherReasonInput.required = true; 
        } else { 
          otherReasonDiv.style.display = 'none'; 
          otherReasonInput.required = false; 
          otherReasonInput.value = ''; 
        }
      });
    }

    // Event listeners for weight and time calculations
    document.getElementById('materialSelect').addEventListener('change', calculateWeight);
    document.querySelectorAll('.calculate').forEach(el => el.addEventListener('input', calculateWeight));
    document.getElementById('startTime').addEventListener('input', calculateProcessTime);
    document.getElementById('endTime').addEventListener('input', calculateProcessTime);

    // Form submission confirmation with proper validation
    window.confirmSubmit = function() {
      if (!document.querySelector('input[name="g_date"]')?.value) { alert("Please select Timestamp."); return false; }
      if (!document.getElementById('customerSelect').value) { alert("Please select Customer."); return false; }
      if (!document.getElementById('projectSelect').value) { alert("Please select Project."); return false; }
      if (!document.getElementById('materialSelect').value) { alert("Please select Material."); return false; }
      if (mureasonSelect && mureasonSelect.value === 'Other/Unclassified' && (!otherReasonInput.value.trim())) { 
        alert("Please specify the reason for 'Other/Unclassified'."); 
        return false; 
      }
      if (mureasonSelect && mureasonSelect.value === 'Other/Unclassified') {
        let hidden = document.createElement('input');
        hidden.type = 'hidden';
        hidden.name = 'other_gmr';
        hidden.value = otherReasonInput.value.trim();
        const existingHidden = document.querySelector('input[name="other_gmr"]');
        if (existingHidden) existingHidden.remove();
        document.getElementById('productionForm').appendChild(hidden);
      }
      return confirm("✅ Save this production record?");
    };

    // Enhanced Reset button handler
    const resetBtn = document.querySelector('button[type="reset"]');
    const dateInput = document.querySelector('input[name="g_date"]');
    if (resetBtn) {
      resetBtn.addEventListener('click', function(e) {
        setTimeout(() => {
          if (dateInput && !dateInput.value) dateInput.value = new Date().toISOString().split('T')[0];
          calculateWeight();
          calculateProcessTime();
          if (mureasonSelect) {
            mureasonSelect.value = '';
            otherReasonDiv.style.display = 'none';
            otherReasonInput.value = '';
            if (mureasonSelect.disabled) mureasonSelect.disabled = false;
            const hiddenClone = document.querySelector('input[name="other_gmr"]');
            if (hiddenClone) hiddenClone.remove();
          }
          const startTimeElem = document.getElementById('startTime');
          const endTimeElem = document.getElementById('endTime');
          if (startTimeElem) startTimeElem.value = '';
          if (endTimeElem) endTimeElem.value = '';
          document.getElementById('processTimeDisplay').value = '';
          document.getElementById('processTimeHidden').value = '';
        }, 20);
      });
    }

    // Set default date to today if empty
    if (dateInput && !dateInput.value) dateInput.value = new Date().toISOString().split('T')[0];
    
    // Initial calculations
    calculateWeight();
    calculateProcessTime();
    
    // Ensure other reason visibility on page load (if pre-selected)
    if (mureasonSelect && mureasonSelect.value === 'Other/Unclassified') {
      otherReasonDiv.style.display = 'block';
    }
    
    console.log("Production entry system ready — weight & process time auto-calculated.");
  </script>
</body>
