            materialName.classList.add('is-invalid');
            materialName.setCustomValidity('Material already exists');
            // Show custom error message
          }
        });
        */
      });
      
      // Clear validation on input
      document.querySelector('input[name="mname"]').addEventListener('input', function() {
        this.classList.remove('is-invalid');
        this.setCustomValidity('');
      });
    }
  });
  
  // Optional: Reset form when modal is closed
  $('#materialModal').on('hidden.bs.modal', function () {
    const form = document.querySelector('#materialForm');
