<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Production Dashboard | Department Overview</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: linear-gradient(145deg, #eef2f7 0%, #d9e0e8 100%);
            min-height: 100vh;
            font-family: 'Segoe UI', 'Inter', system-ui, -apple-system, sans-serif;
        }

        /* ========= MODERN NAVBAR ========= */
        .navbar-custom {
            background: linear-gradient(115deg, #1e3c72 0%, #2a5298 100%);
            padding: 0.5rem 1.5rem;
            box-shadow: 0 12px 28px -8px rgba(0, 0, 0, 0.25);
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }

        .navbar-brand {
            font-weight: 600;
            font-size: 1.6rem;
            letter-spacing: -0.3px;
            color: white !important;
            display: flex;
            align-items: center;
            gap: 12px;
            /* background: rgba(255,255,255,0.06); */
            padding: 0.35rem 1.2rem;
            border-radius: 60px;
            transition: all 0.2s;
        }

        .navbar-brand i {
            font-size: 1.8rem;
            color: #f9c74f;
            filter: drop-shadow(0 2px 3px rgba(0,0,0,0.2));
        }

        .nav-link-custom {
            color: rgba(255, 255, 255, 0.92) !important;
            font-weight: 600;
            margin: 0 0.2rem;
            padding: 0.5rem 1.2rem !important;
            border-radius: 50px;
            transition: all 0.25s ease;
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 0.92rem;
        }

        .nav-link-custom i {
            font-size: 1rem;
            color: #ffde9c;
        }

        .nav-link-custom:hover {
            background: rgba(255, 255, 255, 0.18);
            transform: translateY(-2px);
            color: white !important;
        }

        .nav-link-custom.active {
            background: rgba(249, 199, 79, 0.25);
            color: #fff3cf !important;
            font-weight: 700;
        }

        .dropdown-menu-custom {
            border-radius: 20px;
            border: none;
            box-shadow: 0 15px 35px rgba(0,0,0,0.12);
            padding: 0.5rem;
            margin-top: 8px;
            backdrop-filter: blur(2px);
            background: #fffffffa;
        }

        .dropdown-item-custom {
            border-radius: 14px;
            padding: 8px 18px;
            font-weight: 500;
            transition: 0.2s;
        }

        .dropdown-item-custom:hover {
            background: #eef2fc;
            transform: translateX(4px);
        }

        .navbar-toggler-icon-custom {
            filter: invert(1);
        }

        /* ========= DASHBOARD CARD STYLES ========= */
        .dashboard-card {
            border: none;
            border-radius: 36px;
            background: white;
            box-shadow: 0 25px 45px -12px rgba(0, 0, 0, 0.28);
            overflow: hidden;
            transition: transform 0.2s ease, box-shadow 0.2s;
        }

        .dashboard-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 32px 55px -15px rgba(0, 0, 0, 0.32);
        }

        .dashboard-header {
            background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
            color: white;
            padding: 1rem;
            text-align: center;
            border-bottom: 2px solid #ffdd99;
        }

        .dashboard-header h3 {
            margin: 0;
            font-weight: 700;
            font-size: 1.6rem;
            letter-spacing: -0.2px;
        }

        .dashboard-header h3 i {
            color: #ffd966;
            margin-right: 8px;
        }

        .dashboard-header p {
            margin-top: 8px;
            opacity: 0.85;
            font-size: 0.85rem;
        }

        .menu-btn {
            display: flex;
            align-items: center;
            justify-content: flex-start;
            gap: 18px;
            width: 100%;
            padding: 16px 24px;
            margin-bottom: 14px;
            border: none;
            border-radius: 60px;
            background: #ffffff;
            color: #1f3b4c;
            text-decoration: none;
            font-size: 1rem;
            font-weight: 600;
            transition: all 0.28s ease;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.02), 0 2px 3px rgba(0, 0, 0, 0.03);
            border: 1px solid #eef2f6;
        }

        .menu-btn i {
            font-size: 1.5rem;
            width: 32px;
            text-align: center;
            color: #2c7cb6;
            transition: all 0.2s;
        }

        .menu-btn:hover {
            background: linear-gradient(115deg, #1e3c72 0%, #2a5298);
            color: #ffffff;
            transform: translateX(8px) scale(1.01);
            box-shadow: 0 12px 22px rgba(18, 76, 116, 0.25);
            border-color: transparent;
        }

        .menu-btn:hover i {
            color: #ffde9c;
            transform: scale(1.05);
        }

        .card-body {
            padding: 1.8rem;
        }

        .footer-note {
            background: #fbfefd;
            border-top: 1px solid #e9edf2;
            font-size: 0.7rem;
            text-align: center;
            padding: 12px;
            color: #5584a0;
        }

        @media (max-width: 768px) {
            .navbar-brand {
                font-size: 1.2rem;
                padding: 0.3rem 0.9rem;
            }
            .menu-btn {
                padding: 12px 18px;
                font-size: 0.9rem;
                gap: 12px;
            }
            .menu-btn i {
                font-size: 1.3rem;
                width: 28px;
            }
            .dashboard-header h3 {
                font-size: 1.3rem;
            }
        }

        @media (max-width: 576px) {
            .container {
                padding-left: 12px;
                padding-right: 12px;
            }
            .card-body {
                padding: 1.2rem;
            }
        }
    </style>
</head>
<body>

<!-- ========== TOP NAVIGATION BAR (ADDED) ========== -->
<nav class="navbar navbar-expand-lg navbar-custom sticky-top">
    <div class="container-fluid px-2 px-md-3">
        <a class="navbar-brand" href="/"> 
            <i class="fas fa-industry"></i> NeatWind
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"><i class="fas fa-bars text-white fs-3"></i></span>
        </button>
        <div class="collapse navbar-collapse" id="mainNavbar">
            <ul class="navbar-nav ms-auto mb-2 mb-lg-0 align-items-center gap-1">
                <li class="nav-item">
                    <a class="nav-link nav-link-custom active" href="#">
                        <i class="fas fa-tachometer-alt"></i> Dashboard
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link nav-link-custom" href="#">
                        <i class="fas fa-gear"></i> Settings
                    </a>
                </li>
                <li class="nav-item ms-0 ms-lg-2">
                    <a class="nav-link nav-link-custom" href="https://www.google.com/" style="background: rgba(255,255,255,0.08);">
                        <i class="fas fa-arrow-right-from-bracket"></i> Exit
                    </a>
                </li>
            </ul>
        </div>
    </div>
</nav>

<!-- MAIN DASHBOARD CONTENT -->
<div class="container py-4 py-md-5">
    <div class="row justify-content-center">
        <div class="col-lg-5 col-md-7 col-sm-10">

            <div class="card dashboard-card">
                <div class="dashboard-header">
                    <h3><i class="fas fa-industry me-2"></i> Department Hub</h3>
                    <p><i class="fas fa-bolt me-1"></i> Select any division to view / manage metrics</p>
                </div>

                <div class="card-body p-4">
                    <!-- Department links / menu buttons -->
                    <a href="/deptlogindashboard" class="menu-btn">
                        <i class="fas fa-chart-simple"></i>
                        <span>📊 Laser Department</span>
                    </a>

                     <a href="/deptlogindashboard" class="menu-btn">
                        <i class="fas fa-code"></i>
                        <span>💻 Programming Department</span>
                    </a>

                    <a href="/deptlogindashboard" class="menu-btn">
                        <i class="fas fa-bolt"></i>
                        <span>⚡ Punching Department</span>
                    </a>

                    <a href="/deptlogindashboard" class="menu-btn">
                        <i class="fas fa-drafting-compass"></i>
                        <span>🔩 Bending Department</span>
                    </a>

                    <a href="/deptlogindashboard" class="menu-btn">
                        <i class="fas fa-fire"></i>
                        <span>🔥 Welding Department</span>
                    </a>

                    <a href="/deptlogindashboard" class="menu-btn">
                        <i class="fas fa-paint-roller"></i>
                        <span>🎨 Painting/ Powder Coating </span>
                    </a>

                    <a href="/deptlogindashboard" class="menu-btn">
                        <i class="fas fa-cogs"></i>
                        <span>🛠️ Assembly Department</span>
                    </a>

                    <a href="/deptlogindashboard" class="menu-btn">
                        <i class="fas fa-truck"></i>
                        <span>🚚 Dispatch Department</span>
                    </a>

                    <!-- Extra accent: quick offcuts entry -->
                    <div class="mt-3 pt-2 text-center">
                        <small class="text-muted"><i class="fas fa-sync-alt me-1"></i> Last sync: today · real-time KPIs</small>
                    </div>
                </div>

                <div class="footer-note">
                    <i class="fas fa-database me-1"></i> Integrated with Offcuts Material System • Live production tracking
                </div>
            </div>

        </div>
    </div>
</div>

<!-- Bootstrap JS + Popper for toggles/dropdowns -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<!-- Optional small interactive enhancement: active highlight on click (just UX) -->
<script>
    (function() {
        // small fix for toggler icon (prevent glitch)
        const toggler = document.querySelector('.navbar-toggler');
        if(toggler) {
            toggler.addEventListener('click', function() {
                const icon = this.querySelector('i');
                if(icon) {
                    // just visual flair
                }
            });
        }

        // add a subtle console note
        console.log("✅ Top navbar integrated | Department dashboard ready");
        
        // highlight current menu button if it matches hash or just keep first active
        const currentPath = window.location.pathname;
        const allMenuBtns = document.querySelectorAll('.menu-btn');
        allMenuBtns.forEach(btn => {
            const href = btn.getAttribute('href');
            if(href && href !== '#' && currentPath === href) {
                btn.style.background = "linear-gradient(115deg, #1b5b8c, #124c74)";
                btn.style.color = "white";
                let iconInside = btn.querySelector('i');
                if(iconInside) iconInside.style.color = "#ffde9c";
            }
        });
        
        // navbar active link based on url
        const navLinks = document.querySelectorAll('.nav-link-custom');
        navLinks.forEach(link => {
            const linkHref = link.getAttribute('href');
            if(linkHref && linkHref !== '#' && currentPath === linkHref) {
                document.querySelectorAll('.nav-link-custom').forEach(l => l.classList.remove('active'));
                link.classList.add('active');
            }
        });
    })();
</script>

</body>
</html>