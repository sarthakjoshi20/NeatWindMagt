<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes, maximum-scale=1.5">
  <title>Production Entry | Offcuts Material System</title>

  <!-- Bootstrap 5 & Icons -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      background: linear-gradient(135deg, #f5f7fa 0%, #e9ecef 100%);
      font-family: 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif;
      min-height: 100vh;
      padding: 0;
    }

    .navbar {
      background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
      box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2);
      padding: 0.75rem 1rem;
      margin-bottom: 1.5rem;
    }

    .navbar-brand {
      font-weight: 700;
      font-size: 1.4rem;
      letter-spacing: 0.5px;
      color: white !important;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .navbar-brand i {
      font-size: 1.6rem;
      color: #ffd966;
    }

    .navbar-nav .nav-link {
      color: rgba(255, 255, 255, 0.9) !important;
      font-weight: 500;
      margin: 0 0.2rem;
      padding: 0.5rem 1rem !important;
      border-radius: 30px;
      transition: all 0.25s ease;
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 0.95rem;
    }

    .navbar-nav .nav-link i {
      font-size: 1rem;
      color: #ffd966;
    }

    .navbar-nav .nav-link:hover {
      background: rgba(255, 255, 255, 0.15);
      color: white !important;
      transform: translateY(-1px);
    }

    .navbar-nav .nav-link.active {
      background: rgba(255, 255, 255, 0.2);
      color: white !important;
      font-weight: 600;
      box-shadow: 0 2px 8px rgba(0,0,0,0.15);
    }

    .navbar-toggler {
      border: none;
      color: white;
      font-size: 1.5rem;
      padding: 0.4rem 0.7rem;
      background: rgba(255,255,255,0.15);
      border-radius: 10px;
    }

    .container {
      max-width: 1400px;
      padding-left: 12px;
      padding-right: 12px;
    }

    .card {
      border: none;
      border-radius: 20px;
      box-shadow: 0 20px 35px -12px rgba(0, 0, 0, 0.15);
      overflow: hidden;
      transition: transform 0.2s ease;
    }

    .card:hover {
      transform: translateY(-2px);
    }

    .card-header {
      background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
      border-bottom: none;
      padding: 1rem 1.25rem;
    }

    .card-header h4 {
      font-weight: 600;
      letter-spacing: 0.3px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 12px;
      margin: 0;
      font-size: 1.1rem;
      color: white;
    }

    .card-header h4 i {
      margin-right: 8px;
      font-size: 1.2rem;
    }

    .card-body {
      padding: 1.5rem;
      background: white;
    }

    .form-label {
      font-weight: 600;
      font-size: 0.75rem;
      margin-bottom: 0.4rem;
      color: #2c3e66;
      letter-spacing: 0.5px;
      text-transform: uppercase;
    }

    .form-control,
    .form-select {
      border-radius: 10px;
      border: 1.5px solid #e2e8f0;
      padding: 0.5rem 0.85rem;
      font-size: 0.9rem;
      transition: all 0.2s ease;
      background-color: #fefefe;
    }

    .form-control:focus,
    .form-select:focus {
      border-color: #2a5298;
      box-shadow: 0 0 0 3px rgba(42, 82, 152, 0.15);
      outline: none;
    }

    .form-control[readonly] {
      background-color: #f8f9fc;
      font-weight: 500;
      color: #1e3c72;
    }

    .required {
      color: #dc3545;
      font-weight: 700;
      margin-left: 3px;
    }

    hr {
      margin: 1.2rem 0;
      border: 0;
      height: 2px;
      background: linear-gradient(90deg, transparent, #2a5298, #1e3c72, transparent);
      opacity: 0.3;
    }

    .btn-success {
      background: linear-gradient(135deg, #28a745 0%, #218838 100%);
      border: none;
      border-radius: 40px;
      padding: 0.6rem 1.5rem;
      font-weight: 600;
      font-size: 0.9rem;
      transition: all 0.2s;
      box-shadow: 0 3px 8px rgba(40, 167, 69, 0.25);
    }

    .btn-success:hover {
      transform: translateY(-1px);
      box-shadow: 0 5px 12px rgba(40, 167, 69, 0.35);
    }

    .btn-secondary {
      border-radius: 40px;
      padding: 0.6rem 1.5rem;
      font-size: 0.9rem;
    }

    .btn-sm {
      border-radius: 40px;
      font-weight: 500;
      padding: 0.35rem 1rem;
      font-size: 0.75rem;
    }

    .badge-soft {
      background: #eef2ff;
      color: #1e3c72;
      border-radius: 30px;
      padding: 4px 10px;
      font-size: 0.65rem;
    }

    .text-muted-info {
      font-size: 0.7rem;
      color: #6c8dae;
      margin-top: 5px;
      display: inline-block;
    }

    @media (max-width: 768px) {
      .card-header h4 {
        flex-direction: column;
        align-items: stretch;
        text-align: center;
      }
      .btn-success, .btn-secondary {
        width: 100%;
      }
    }

    @media (max-width: 576px) {
      .card-body {
        padding: 1rem;
      }
      .form-control, .form-select {
        font-size: 0.85rem;
      }
    }

    .reset-notice {
      background: #eef2ff;
      border-left: 4px solid #2a5298;
      font-size: 0.7rem;
      padding: 4px 12px;
      border-radius: 20px;
      display: inline-block;
    }
  </style>
</head>
<body>

  <nav class="navbar navbar-expand-lg">
    <div class="container-fluid">
      <a class="navbar-brand" href="/">
        <i class="fas fa-industry"></i> NeatWind
      </a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarLinks" 
              aria-controls="navbarLinks" aria-expanded="false" aria-label="Toggle navigation">
        <i class="fas fa-bars"></i>
      </button>
      <div class="collapse navbar-collapse" id="navbarLinks">
        <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
          <li class="nav-item">
            <a class="nav-link active" href="#"><i class="fas fa-plus-circle"></i> New Entry</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/dailyproductionrecord"><i class="fas fa-chart-line"></i> Records Dashboard</a>
          </li>
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" id="addNewDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
              <i class="fas fa-folder-plus"></i> Add New Option
            </a>
            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="addNewDropdown">
              <li><a class="dropdown-item" data-bs-toggle="modal" data-bs-target="#operatorModal"><i class="fas fa-plus-circle"></i> Operator Name</a></li>
              <li><a class="dropdown-item" data-bs-toggle="modal" data-bs-target="#customerModal"><i class="fas fa-plus-circle"></i> Customer Name</a></li>
              <li><a class="dropdown-item" data-bs-toggle="modal" data-bs-target="#projectModal"><i class="fas fa-plus-circle"></i> Project Name</a></li>
              <li><a class="dropdown-item" data-bs-toggle="modal" data-bs-target="#materialModal"><i class="fas fa-plus-circle"></i> Material</a></li>
            </ul>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <div class="container py-3 py-md-4">
    <div class="card">
      <div class="card-header bg-primary text-white">
        <h4 class="mb-0">
          <i class="fas fa-cube me-2"></i> Daily Production Entry Form
          <a href="/dailyproductionrecord" style="text-decoration: none;">
            <button class="btn btn-success btn-sm" type="button">
              <i class="fas fa-chart-simple me-1"></i> Production & Downtime Records
            </button>
          </a>
        </h4>
      </div>

      <div class="card-body">
        <form method="post" action="/save_details" id="productionForm">
          <div class="row g-3 g-md-4">
            <div class="col-12 col-sm-6 col-md-4">
              <label class="form-label"><i class="far fa-calendar-alt me-1"></i> Timestamp <span class="required">*</span></label>
              <input type="date" class="form-control" name="g_date" id="g_date" required>
            </div>

            <div class="col-12 col-sm-6 col-md-4">
              <label class="form-label"><i class="fas fa-user-circle me-1"></i> Operator Name</label>
              <select name="g_operator_name" class="form-select" id="operatorSelect">
                <option value="">-- Select Operator Name --</option>
                <% for(let i = 0; i < operator.length; i++) { %>
                        <option value="<%= operator[i].oname %>">
                            <%= operator[i].oname %>
                        </option>
                <% } %>
              </select>
            </div>

            <div class="col-12 col-sm-6 col-md-4">
              <label class="form-label"><i class="fas fa-clock me-1"></i> Shift</label>
              <select class="form-select" name="g_shift">
                <option value="">-- Select Shift --</option>
                <option value="1st">1st</option>
                <option value="2nd">2nd</option>
                <option value="3rd">3rd</option>
              </select>
            </div>

            <div class="col-12 col-md-4">
                <label class="form-label">
                    <i class="fas fa-building me-1"></i> Customer Name
                    <span class="required">*</span>
                </label>
                <select name="g_customer" id="customerSelect" class="form-select" required>
                    <option value="">-- Select Customer --</option>
                    <% for(let i=0; i<customer.length; i++){ %>
                        <option value="<%= customer[i].cname %>">
                            <%= customer[i].cname %>
                        </option>
                    <% } %>
                </select>
            </div>

            <div class="col-12 col-md-4">
              <label class="form-label"><i class="fas fa-diagram-project me-1"></i> Project Name <span class="required">*</span></label>
              <select name="g_project_name" id="projectSelect" class="form-select" required>
                  <option value="">-- Select Project --</option>
              </select>
            </div>

            <div class="col-12 col-sm-6 col-md-4">
              <label class="form-label"><i class="fas fa-layer-group me-1"></i> Set</label>
              <select name="g_set_name" id="setSelect" class="form-select">
                <option value="">-- Select Set --</option>
                <% for(let i = 0; i < 200 ; i++) { %>
                        <option value="<%= i + 1 %>">
                            <%= i+1 %>
                        </option>
                <% } %>
              </select>
            </div>

            <div class="col-12 col-sm-6 col-md-4">
              <label class="form-label"><i class="fas fa-database me-1"></i> Material <span class="required">*</span></label>
              <select name="g_material" id="materialSelect" class="form-select" required>
                <option value="">-- Select Material --</option>
                <% for(let i = 0; i < material.length; i++) { %>
                        <option value="<%= material[i].mname %>">
                            <%= material[i].mname %>
                        </option>
                    <% } %>
              </select>
            </div>

            <div class="col-12 col-sm-6 col-md-4">
              <label class="form-label"><i class="fas fa-hashtag me-1"></i> Sheet Qty</label>
              <select id="qty" class="form-select calculate" name="g_sheetqty">
                    <option value="">-- Select Sheet Quantity --</option>
                        <% for(let i = 0; i < 100 ; i++) { %>
                            <option value="<%= i + 1 %>">
                                <%= i+1 %>
                            </option>
                        <% } %>
              </select>
            </div>
            <div class="col-12 col-sm-6 col-md-4">
              <label class="form-label"><i class="fas fa-arrows-left-right me-1"></i> Length (mm)</label>
              <input type="number" step="0.01" id="length" class="form-control calculate" name="g_length" placeholder="mm">
            </div>
            <div class="col-12 col-sm-6 col-md-4">
              <label class="form-label"><i class="fas fa-arrows-up-down me-1"></i> Width (mm)</label>
              <input type="number" step="0.01" id="width" class="form-control calculate" name="g_width" placeholder="mm">
            </div>
            <div class="col-12 col-sm-6 col-md-4">
              <label class="form-label"><i class="fas fa-chart-line me-1"></i> Thickness (mm)</label>
              <input type="number" step="0.01" id="thickness" class="form-control calculate" name="g_thickness" placeholder="mm">
            </div>
            <div class="col-12 col-md-4">
              <label class="form-label"><i class="fas fa-weight-hanging me-1"></i> Total Weight (Kg)</label>
              <input type="text" id="totalWeight" class="form-control bg-light" readonly name="g_totalweight" placeholder="Auto calculated (density-based)">
            </div>
            <div class="col-12 col-md-4">
              <label class="form-label"><i class="fas fa-hourglass-half me-1"></i> Machine Start Time (HH:MM)</label>
              <input type="time" class="form-control" id="startTime" step="60" name="g_start_time">
            </div>
            <div class="col-12 col-md-4">
              <label class="form-label"><i class="fas fa-hourglass-half me-1"></i> Machine End Time (HH:MM)</label>
              <input type="time" class="form-control" id="endTime" step="60" name="g_end_time">
            </div>
            <div class="col-12 col-md-4">
              <label class="form-label"><i class="fas fa-hourglass-half me-1"></i> Process Time (HH:MM)</label>
              <input type="text" class="form-control bg-light" id="processTimeDisplay" readonly placeholder="Auto calculated (HH:MM)">
              <input type="hidden" id="processTimeHidden" name="g_process_time">
            </div>

            <div class="col-12"><hr></div>

            <div class="col-12 col-md-6">
              <label class="form-label"><i class="fas fa-tools me-1"></i> Machine Undermaintenance Time (min)</label>
              <input type="time" class="form-control" name="g_m_processtime" placeholder="eg 2:30 Min">
            </div>
            <div class="col-12 col-md-6">
              <label class="form-label"><i class="fas fa-exclamation-triangle me-1"></i> Machine Undermaintenance Reason</label>
              <select class="form-select" id="mureasonSelect" name="g_mureason">
                <option value="">-- Select Reason --</option>
                <option value="Mechanical Issue">🔧 Mechanical Issue</option>
                <option value="Electrical fault">⚡ Electrical fault</option>
                <option value="Material Shortage">📦 Material Shortage</option>
                <option value="Power Interruption">🔌 Power Interruption</option>
                <option value="Sanctioned Break">☕ Sanctioned Break</option>
                <option value="Line Changeover">🔄 Line Changeover</option>
                <option value="Other/Unclassified">❓ Other/Unclassified</option>
              </select>
              <div id="otherReasonDiv" style="display: none; margin-top: 10px;">
                <input type="text" class="form-control" name="other_gmr" id="otherReasonInput" placeholder="Please specify the reason..." value="">
                <small class="text-muted-info"><i class="fas fa-info-circle"></i> Please provide details</small>
              </div>
            </div>
            <div class="col-12 col-md-6">
              <label class="form-label"><i class="fas fa-clipboard-list me-1"></i> Justification & Corrective Action</label>
              <input type="text" class="form-control" name="g_mjustification" placeholder="Describe actions taken">
            </div>
            <div class="col-12 col-md-6">
              <label class="form-label"><i class="fas fa-times-circle me-1"></i> Rejection Quantity</label>
              <input type="text" class="form-control" name="g_rejectionqty" placeholder="Number of rejected parts">
            </div>

            <div class="col-12">
              <div class="d-flex flex-column flex-sm-row justify-content-end gap-3 mt-3">
                <button type="reset" class="btn btn-secondary px-4 py-2 order-2 order-sm-1"><i class="fas fa-undo-alt me-1"></i> Reset</button>
                <button type="submit" onclick="return confirmSubmit()" class="btn btn-success px-5 py-2 order-1 order-sm-2"><i class="fas fa-save me-2"></i> Save Record</button>
              </div>
            </div>
          </div>
        </form>
      </div>
      <div class="card-footer bg-white border-0 text-center pb-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
        <span class="badge-soft"><i class="fas fa-chart-line"></i> Material Density (g/cm³): MS=7.85, ALUMINIUM=2.70, SS=7.93, GI=7.85, HRPO=7.85, PERFORATED=7.85 | Weight = L×W×Th×Qty × (Density/1000) kg</span>
        <span class="reset-notice"><i class="fas fa-sync-alt"></i> Session data only — no local storage</span>
      </div>
    </div>
  </div>

<!-- Operator Modal -->
<div class="modal fade" id="operatorModal" tabindex="-1" aria-labelledby="operatorModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="operatorModalLabel">Add New Operator</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <form action="/save_operator" method="post">
            <label class="form-label">Select Department :</label>
            <select name="deptname" class="from form-select" required>
                <option value="">-- Select Department --</option>
                <option value="Daily Production Reports">Daily Production Reports</option>
                <option value="Punching Department">Punching Department</option>
                <option value="Programming Department">Programming Department</option>
                <option value="Operating Department">Operating Department</option>
                <option value="Welding Department">Welding Department</option>
                <option value="Coating & Binding">Coating & Binding</option>
            </select>
            <label class="form-label">Operator Name :</label>
            <input type="text" name="oname" class="form-control" required>
            <div class="mt-3 text-end">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="submit" class="btn btn-primary">Save changes</button>
            </div>
        </form>
      </div>
    </div>
  </div>
</div>

<!-- Customer Modal -->
<div class="modal fade" id="customerModal" tabindex="-1" aria-labelledby="customerModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="customerModalLabel">Add New Customer</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <form action="/save_customer" method="post">
            <label class="form-label">Customer Name :</label>
            <input type="text" name="cname" class="form-control">
            <div class="mt-3 text-end">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="submit" class="btn btn-primary">Save changes</button>
            </div>
        </form>
      </div>
    </div>
  </div>
</div>

<!-- Project Modal -->
<div class="modal fade" id="projectModal" tabindex="-1" aria-labelledby="projectModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="projectModalLabel">Add New Project</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <form action="/save_project" method="post">
            <label class="form-label">Customer Name :</label>
            <select name="cuname" class="form-select" required>
                    <option value="">-- Select Customer --</option>
                <% for(let i = 0; i < customer.length; i++){ %>
                    <option value="<%= customer[i].cname %>">
                        <%= customer[i].cname %>
                    </option>
                <% } %>
            </select>

            <label class="form-label mt-2">Project Name :</label>
            <input type="text" name="pname" class="form-control" required>
            <div class="mt-3 text-end">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="submit" class="btn btn-primary">Save changes</button>
            </div>
        </form>
      </div>
    </div>
  </div>
</div>

<!-- Material Modal -->
<div class="modal fade" id="materialModal" tabindex="-1" aria-labelledby="materialModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="materialModalLabel">Add New Material</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <form action="/save_material" method="post">
            <label class="form-label">Material Name :</label>
            <input type="text" name="mname" class="form-control" required>
            <div class="mt-3 text-end">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="submit" class="btn btn-primary">Save changes</button>
            </div>
        </form>
      </div>
    </div>
  </div>
</div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

  <script>
    // Density mapping (g/cm³)
    const materialDensity = {
      "MS": 7.85,
      "ALUMINIUM": 2.70,
      "SS": 7.93,
      "GI": 7.85,
      "HRPO": 7.85,
      "PERFORATED": 7.85
    };

    // Material density-based weight calculation
    function calculateWeight() {
      let L = parseFloat(document.getElementById('length').value) || 0;
      let W = parseFloat(document.getElementById('width').value) || 0;
      let T = parseFloat(document.getElementById('thickness').value) || 0;
      let Q = parseFloat(document.getElementById('qty').value) || 0;
      let selectedMaterial = document.getElementById('materialSelect').value;
      let density = materialDensity[selectedMaterial] || 7.85;
      let weight = (L * W * T * Q * density) / 1000000;
      if (isNaN(weight) || weight <= 0) weight = 0;
      document.getElementById('totalWeight').value = weight.toFixed(3) + " Kg";
    }

    // Process time calculation (HH:MM) from start & end times
    function calculateProcessTime() {
      const start = document.getElementById('startTime').value;
      const end = document.getElementById('endTime').value;
      if (!start || !end) {
        document.getElementById('processTimeDisplay').value = '';
        document.getElementById('processTimeHidden').value = '';
        return;
      }
      const [startHour, startMin] = start.split(':').map(Number);
      const [endHour, endMin] = end.split(':').map(Number);
      let startTotal = startHour * 60 + startMin;
      let endTotal = endHour * 60 + endMin;
      let diffMinutes = endTotal - startTotal;
      if (diffMinutes < 0) diffMinutes += 24 * 60;
      const hours = Math.floor(diffMinutes / 60);
      const minutes = diffMinutes % 60;
      const formatted = `${hours.toString().padStart(2,'0')}:${minutes.toString().padStart(2,'0')}`;
      document.getElementById('processTimeDisplay').value = formatted;
      document.getElementById('processTimeHidden').value = formatted;
    }

    // Dynamic project loading based on selected customer
    document.getElementById("customerSelect").addEventListener("change", async function () {
      let customer = this.value;
      let projectSelect = document.getElementById("projectSelect");

      if (!customer) {
        projectSelect.innerHTML = '<option value="">-- Select Project --</option>';
        return;
      }

      projectSelect.innerHTML = '<option value="">Loading...</option>';

      try {
        let response = await fetch(`/get_projects/${customer}`);
        let projects = await response.json();
        projectSelect.innerHTML = '<option value="">-- Select Project --</option>';
        projects.forEach(project => {
          projectSelect.innerHTML += `<option value="${project.pname}">${project.pname}</option>`;
        });
      } catch(e) {
        projectSelect.innerHTML = '<option value="">-- Error loading projects --</option>';
      }
    });

    // Other reason logic (fixed: using "Other/Unclassified" value)
    const mureasonSelect = document.getElementById('mureasonSelect');
    const otherReasonDiv = document.getElementById('otherReasonDiv');
    const otherReasonInput = document.getElementById('otherReasonInput');
    
    if (mureasonSelect) {
      mureasonSelect.addEventListener('change', function() {
        if (mureasonSelect.value === 'Other/Unclassified') { 
          otherReasonDiv.style.display = 'block'; 
          otherReasonInput.required = true; 
        } else { 
          otherReasonDiv.style.display = 'none'; 
          otherReasonInput.required = false; 
          otherReasonInput.value = ''; 
        }
      });
    }

    // Event listeners for weight and time calculations
    document.getElementById('materialSelect').addEventListener('change', calculateWeight);
    document.querySelectorAll('.calculate').forEach(el => el.addEventListener('input', calculateWeight));
    document.getElementById('startTime').addEventListener('input', calculateProcessTime);
    document.getElementById('endTime').addEventListener('input', calculateProcessTime);

    // Form submission confirmation with proper validation
    window.confirmSubmit = function() {
      if (!document.querySelector('input[name="g_date"]')?.value) { alert("Please select Timestamp."); return false; }
      if (!document.getElementById('customerSelect').value) { alert("Please select Customer."); return false; }
      if (!document.getElementById('projectSelect').value) { alert("Please select Project."); return false; }
      if (!document.getElementById('materialSelect').value) { alert("Please select Material."); return false; }
      if (mureasonSelect && mureasonSelect.value === 'Other/Unclassified' && (!otherReasonInput.value.trim())) { 
        alert("Please specify the reason for 'Other/Unclassified'."); 
        return false; 
      }
      if (mureasonSelect && mureasonSelect.value === 'Other/Unclassified') {
        let hidden = document.createElement('input');
        hidden.type = 'hidden';
        hidden.name = 'other_gmr';
        hidden.value = otherReasonInput.value.trim();
        const existingHidden = document.querySelector('input[name="other_gmr"]');
        if (existingHidden) existingHidden.remove();
        document.getElementById('productionForm').appendChild(hidden);
      }
      return confirm("✅ Save this production record?");
    };

    // Enhanced Reset button handler
    const resetBtn = document.querySelector('button[type="reset"]');
    const dateInput = document.querySelector('input[name="g_date"]');
    if (resetBtn) {
      resetBtn.addEventListener('click', function(e) {
        setTimeout(() => {
          if (dateInput && !dateInput.value) dateInput.value = new Date().toISOString().split('T')[0];
          calculateWeight();
          calculateProcessTime();
          if (mureasonSelect) {
            mureasonSelect.value = '';
            otherReasonDiv.style.display = 'none';
            otherReasonInput.value = '';
            if (mureasonSelect.disabled) mureasonSelect.disabled = false;
            const hiddenClone = document.querySelector('input[name="other_gmr"]');
            if (hiddenClone) hiddenClone.remove();
          }
          const startTimeElem = document.getElementById('startTime');
          const endTimeElem = document.getElementById('endTime');
          if (startTimeElem) startTimeElem.value = '';
          if (endTimeElem) endTimeElem.value = '';
          document.getElementById('processTimeDisplay').value = '';
          document.getElementById('processTimeHidden').value = '';
        }, 20);
      });
    }

    // Set default date to today if empty
    if (dateInput && !dateInput.value) dateInput.value = new Date().toISOString().split('T')[0];
    
    // Initial calculations
    calculateWeight();
    calculateProcessTime();
    
    // Ensure other reason visibility on page load (if pre-selected)
    if (mureasonSelect && mureasonSelect.value === 'Other/Unclassified') {
      otherReasonDiv.style.display = 'block';
    }
    
    console.log("Production entry system ready — weight & process time auto-calculated.");
  </script>
</body>
</html>