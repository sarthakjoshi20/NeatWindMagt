<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes, maximum-scale=1.5">
    <title>Edit Record | Offcuts Material System</title>

    <!-- Bootstrap 5 + Font Awesome + Google Fonts -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">

    <style>
        * {
            font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', sans-serif;
        }

        body {
            background: linear-gradient(145deg, #eef2f9 0%, #e0e8f2 100%);
            padding: 1rem;
            min-height: 100vh;
        }

        .update-card {
            border: none;
            border-radius: 28px;
            box-shadow: 0 20px 35px -12px rgba(0, 0, 0, 0.2), 0 1px 3px rgba(0, 0, 0, 0.02);
            overflow: hidden;
            transition: all 0.2s;
            background: white;
        }

        .card-header-custom {
            background: linear-gradient(105deg, #1a4d6b 0%, #1f6e8c 100%);
            padding: 1rem 1.5rem;
            border-bottom: none;
        }

        .card-header-custom h4 {
            font-weight: 700;
            letter-spacing: -0.2px;
            font-size: 1.3rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 12px;
            margin: 0;
        }

        .btn-records {
            background: rgba(255,255,255,0.18);
            border: 1px solid rgba(255,255,255,0.4);
            color: white;
            border-radius: 60px;
            padding: 0.35rem 1rem;
            font-weight: 500;
            transition: 0.2s;
            font-size: 0.75rem;
            white-space: nowrap;
            text-decoration: none;
        }

        .btn-records:hover {
            background: white;
            color: #1f6e8c;
            border-color: white;
            transform: translateY(-1px);
        }

        .form-label {
            font-weight: 600;
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.4px;
            color: #1f4e6e;
            margin-bottom: 0.3rem;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .form-label i {
            font-size: 0.8rem;
            color: #2c7da0;
            width: 1.1rem;
        }

        .form-control, .form-select {
            border-radius: 14px;
            border: 1.5px solid #e2edf2;
            padding: 0.6rem 0.9rem;
            font-weight: 500;
            background-color: #ffffff;
            transition: all 0.2s ease;
            font-size: 0.85rem;
        }

        .form-control:focus, .form-select:focus {
            border-color: #2c7da0;
            box-shadow: 0 0 0 3px rgba(44,125,160,0.15);
            outline: none;
        }

        .bg-light-readonly {
            background-color: #f4f9fe;
            font-weight: 600;
            color: #0b4f6c;
        }

        hr {
            opacity: 0.4;
            margin: 0.8rem 0;
        }

        .btn-update {
            background: linear-gradient(95deg, #1f6e43, #118c5e);
            border: none;
            padding: 0.7rem 1.5rem;
            font-weight: 700;
            border-radius: 50px;
            font-size: 0.85rem;
            transition: 0.2s;
            box-shadow: 0 6px 14px -6px rgba(17,140,94,0.4);
            letter-spacing: 0.3px;
        }

        .btn-update:hover {
            background: linear-gradient(95deg, #0e593a, #0b7550);
            transform: translateY(-2px);
            box-shadow: 0 10px 18px -8px #118c5e;
        }

        .btn-update i {
            margin-right: 6px;
        }

        .btn-back-outline {
            background: transparent;
            border: 1.5px solid #b9d4e5;
            color: #1f5e7e;
            font-weight: 600;
            padding: 0.65rem 1.4rem;
            border-radius: 50px;
            transition: 0.2s;
            font-size: 0.85rem;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

        .btn-back-outline:hover {
            background: #eef5fc;
            border-color: #2c7da0;
            transform: translateY(-1px);
            color: #1f5e7e;
        }

        .action-buttons {
            display: flex;
            gap: 1rem;
            align-items: center;
            flex-wrap: wrap;
        }

        .card-body {
            padding: 1.8rem;
        }

        small.text-muted-info {
            font-size: 0.7rem;
            display: inline-block;
            margin-top: 6px;
            color: #6c8dae;
        }

        .required-star {
            color: #dc3545;
            font-size: 1rem;
            margin-left: 2px;
        }

        @media (max-width: 992px) {
            .card-body { padding: 1.5rem; }
        }

        @media (max-width: 768px) {
            body { padding: 0.8rem; }
            .card-header-custom { padding: 0.9rem 1.2rem; }
            .card-header-custom h4 { font-size: 1.1rem; flex-direction: column; align-items: stretch; text-align: center; }
            .btn-records { width: 100%; text-align: center; white-space: normal; }
            .card-body { padding: 1.2rem; }
            .form-label { font-size: 0.65rem; }
            .form-control, .form-select { padding: 0.5rem 0.8rem; font-size: 0.8rem; }
            .btn-update, .btn-back-outline { width: 100%; justify-content: center; }
            .action-buttons { flex-direction: column; gap: 12px !important; }
        }

        @media (max-width: 576px) {
            .card-header-custom h4 { font-size: 1rem; }
            .card-body { padding: 1rem; }
            .form-label { font-size: 0.6rem; }
            .form-control, .form-select { padding: 0.45rem 0.7rem; font-size: 0.75rem; border-radius: 12px; }
            .btn-update, .btn-back-outline { padding: 0.55rem 1.2rem; font-size: 0.8rem; }
        }

        @media (max-width: 480px) {
            .container { padding-left: 6px; padding-right: 6px; }
            .card-header-custom { padding: 0.75rem; }
            .card-body { padding: 0.85rem; }
        }

        @media (hover: none) and (pointer: coarse) {
            .form-control, .form-select, .btn-update, .btn-back-outline { min-height: 44px; }
        }

        .process-time-field {
            background-color: #f0f7fc;
            font-weight: 600;
            font-family: 'Inter', monospace;
        }
        .badge-auto {
            background: #e2f0e8;
            color: #1f6e43;
            font-size: 0.6rem;
            border-radius: 30px;
            padding: 2px 8px;
            margin-left: 8px;
        }
    </style>
</head>
<body>

<div class="container py-2">
    <div class="update-card">
        <div class="card-header-custom">
            <h4 class="mb-0 text-white">
                <span><i class="fas fa-pen-ruler me-2"></i> Edit Production Record</span>

                <% if(orole == "admin"){ %>
                    <a href="/admin_punching_dashboard" class="btn-records">
                        <i class="fas fa-chart-simple me-1"></i> Production & Downtime Records
                    </a>
                <% }else{ %>
                    <a href="/punchingproductionrecord" class="btn-records">
                        <i class="fas fa-chart-simple me-1"></i> Production & Downtime Records
                    </a>
                <% } %>
            </h4>
        </div>

        <div class="card-body">
            <form method="post" action="/update_punchinp_details" id="updateForm">
                <!-- hidden ID field - necessary to identify record -->
                <input type="hidden" name="p_id" id="p_id" value="<%= data.p_id %>">

                <div class="row g-3 g-md-4">
                    <!-- Timestamp display (read-only) -->
                    <div class="col-12 col-sm-6 col-md-4">
                        <label class="form-label">
                            <i class="far fa-calendar-alt"></i> Timestamp <span class="required-star">*</span>
                        </label>
                        <input type="text" class="form-control bg-light-readonly" readonly value="<%= data.p_date ? new Date(data.p_date).toLocaleDateString('en-GB') : '' %>">
                        <small class="text-muted-info"><i class="fas fa-info-circle"></i> Date is preserved</small>
                    </div>

                    <!-- Operator Name -->
                    <div class="col-12 col-sm-6 col-md-4">
                        <label class="form-label"><i class="fas fa-user-circle"></i> Operator Name</label>
                        <input style="background-color: #f3faff;" type="text" class="form-control" name="p_operator_name" id="operatorName" value="<%= data.p_operator_name || '' %>" placeholder="Operator name" readonly>
                    </div>

                    <!-- Shift dropdown -->
                    <div class="col-12 col-sm-6 col-md-4">
                        <label class="form-label"><i class="fas fa-exchange-alt"></i> Shift</label>
                        <select class="form-select" name="p_shift" id="shiftSelect">
                            <option value="">-- Select Shift --</option>
                            <option value="1st" <%= data.p_shift === '1st' ? 'selected' : '' %>>1st Shift</option>
                            <option value="2nd" <%= data.p_shift === '2nd' ? 'selected' : '' %>>2nd Shift</option>
                            <option value="3rd" <%= data.p_shift === '3rd' ? 'selected' : '' %>>3rd Shift</option>
                        </select>
                    </div>

                    <!-- Machine dropdown -->
                    <div class="col-12 col-sm-6 col-md-4">
                        <label class="form-label"><i class="fas fa-exchange-alt"></i> Machine</label>
                        <select class="form-select" name="p_machine">
                            <option value="">-- Select Machine --</option>
                            <option value="Amada" <%= data.p_machine === 'Amada' ? 'selected' : '' %>>Amada</option>
                            <option value="Accur Max" <%= data.p_machine === 'Accur Max' ? 'selected' : '' %>>Accur Max</option>
                        </select>
                    </div>

                    <!-- Customer Name -->
                    <div class="col-12 col-md-4">
                        <label class="form-label"><i class="fas fa-building"></i> Customer Name <span class="required-star">*</span></label>
                        <select name="p_customer" id="customerSelect" class="form-select" required>
                            <option value="">-- Select Customer --</option>
                            <% if (typeof customer !== 'undefined' && customer.length) { 
                                for(let i=0; i<customer.length; i++){ 
                                    let selectedAttr = (customer[i].cname === data.p_customer) ? 'selected' : '';
                            %>
                                <option value="<%= customer[i].cname %>" <%= selectedAttr %>><%= customer[i].cname %></option>
                            <% } } else { %>
                                <option value="Transfix" <%= data.p_customer === 'Transfix' ? 'selected' : '' %>>Transfix</option>
                                <option value="Cooper" <%= data.p_customer === 'Cooper' ? 'selected' : '' %>>Cooper</option>
                                <option value="Techmesh" <%= data.p_customer === 'Techmesh' ? 'selected' : '' %>>Techmesh</option>
                                <option value="Bharat Forge" <%= data.p_customer === 'Bharat Forge' ? 'selected' : '' %>>Bharat Forge</option>
                                <option value="Cummins" <%= data.p_customer === 'Cummins' ? 'selected' : '' %>>Cummins</option>
                                <option value="Kirloskar Oil Engines Ltd" <%= data.p_customer === 'Kirloskar Oil Engines Ltd' ? 'selected' : '' %>>Kirloskar Oil Engines Ltd</option>
                                <option value="Atlanta" <%= data.p_customer === 'Atlanta' ? 'selected' : '' %>>Atlanta</option>
                                <option value="Inyantra" <%= data.p_customer === 'Inyantra' ? 'selected' : '' %>>Inyantra</option>
                                <option value="Ecoforst" <%= data.p_customer === 'Ecoforst' ? 'selected' : '' %>>Ecoforst</option>
                                <option value="Finale Panel" <%= data.p_customer === 'Finale Panel' ? 'selected' : '' %>>Finale Panel</option>
                                <option value="Monk Automation" <%= data.p_customer === 'Monk Automation' ? 'selected' : '' %>>Monk Automation</option>
                                <option value="Rutvij" <%= data.p_customer === 'Rutvij' ? 'selected' : '' %>>Rutvij</option>
                                <option value="Avihas" <%= data.p_customer === 'Avihas' ? 'selected' : '' %>>Avihas</option>
                                <option value="Theysohn" <%= data.p_customer === 'Theysohn' ? 'selected' : '' %>>Theysohn</option>
                                <option value="Man" <%= data.p_customer === 'Man' ? 'selected' : '' %>>Man</option>
                            <% } %>
                        </select>
                    </div>

                    <!-- Project Name -->
                    <div class="col-12 col-md-4">
                        <label class="form-label"><i class="fas fa-diagram-project"></i> Project Name <span class="required-star">*</span></label>
                        <input style="background-color: #f3faff;" type="text" class="form-control" name="p_project_name" id="projectName" value="<%= data.p_project_name || '' %>" placeholder="Project name" readonly>
                    </div>

                    <!-- Set Name -->
                    <div class="col-12 col-sm-6 col-md-4">
                        <label class="form-label"><i class="fas fa-layer-group"></i> Set</label>
                        <input type="text" class="form-control" name="p_set_name" id="setName" value="<%= data.p_set_name || '' %>" placeholder="e.g., Set 1, Set A">
                    </div>

                    <!-- Material Name -->
                    <div class="col-12 col-sm-6 col-md-4">
                        <label class="form-label"><i class="fas fa-cube"></i> Material <span class="required-star">*</span></label>
                        <select name="p_material" id="materialSelect" class="form-select" required>
                            <option value="">-- Select Material --</option>
                            <% if (typeof material !== 'undefined' && material.length) { 
                                for(let i=0; i<material.length; i++){ 
                                    let selectedMat = (material[i].mname === data.p_material) ? 'selected' : '';
                            %>
                                <option value="<%= material[i].mname %>" <%= selectedMat %>><%= material[i].mname %></option>
                            <% } } else { %>
                                <option value="MS" <%= data.p_material === 'MS' ? 'selected' : '' %>>MS (7.85 g/cm³)</option>
                                <option value="ALUMINIUM" <%= data.p_material === 'ALUMINIUM' ? 'selected' : '' %>>ALUMINIUM (2.70 g/cm³)</option>
                                <option value="SS" <%= data.p_material === 'SS' ? 'selected' : '' %>>SS (7.93 g/cm³)</option>
                                <option value="GI" <%= data.p_material === 'GI' ? 'selected' : '' %>>GI (7.85 g/cm³)</option>
                                <option value="HRPO" <%= data.p_material === 'HRPO' ? 'selected' : '' %>>HRPO (7.85 g/cm³)</option>
                                <option value="PERFORATED" <%= data.p_material === 'PERFORATED' ? 'selected' : '' %>>PERFORATED (7.85 g/cm³)</option>
                            <% } %>
                        </select>
                    </div>

                    <!-- Sheet Quantity -->
                    <div class="col-12 col-sm-6 col-md-4">
                        <label class="form-label"><i class="fas fa-tablets"></i> Sheet Qty</label>
                        <input type="number" min="0" step="1" id="sheetQty" class="form-control calculate" name="p_sheetqty" value="<%= data.p_sheetqty || '' %>" placeholder="Quantity">
                    </div>

                    <!-- Length -->
                    <div class="col-12 col-sm-6 col-md-3">
                        <label class="form-label"><i class="fas fa-ruler-combined"></i> Length (mm)</label>
                        <input type="number" step="0.01" id="length" class="form-control calculate" name="p_length" value="<%= data.p_length || '' %>" placeholder="mm">
                    </div>

                    <!-- Width -->
                    <div class="col-12 col-sm-6 col-md-3">
                        <label class="form-label"><i class="fas fa-arrows-alt-h"></i> Width (mm)</label>
                        <input type="number" step="0.01" id="width" class="form-control calculate" name="p_width" value="<%= data.p_width || '' %>" placeholder="mm">
                    </div>

                    <!-- Thickness -->
                    <div class="col-12 col-sm-6 col-md-3">
                        <label class="form-label"><i class="fas fa-chart-line"></i> Thickness (mm)</label>
                        <input type="number" step="0.01" id="thickness" class="form-control calculate" name="p_thickness" value="<%= data.p_thickness || '' %>" placeholder="mm">
                    </div>

                    <!-- Total Weight auto-calc -->
                    <div class="col-12 col-md-3">
                        <label class="form-label"><i class="fas fa-weight-hanging"></i> Total Weight (Kg)</label>
                        <input type="text" id="totalWeight" class="form-control bg-light-readonly" readonly name="p_totalweight" value="<%= data.p_totalweight || '' %>">
                        <small class="text-muted-info"><i class="fas fa-calculator"></i> Auto (L×W×T×Qty×Density/10⁶)</small>
                    </div>

                    <!-- MACHINE START TIME & END TIME + AUTO PROCESS TIME -->
                    <div class="col-12 col-md-4">
                        <label class="form-label"><i class="fas fa-play-circle"></i> Machine Start Time (HH:MM)</label>
                        <input type="time" class="form-control" id="startTime" name="p_start_time" value="<%= data.p_start_time || '' %>" step="60">
                    </div>
                    <div class="col-12 col-md-4">
                        <label class="form-label"><i class="fas fa-stop-circle"></i> Machine End Time (HH:MM)</label>
                        <input type="time" class="form-control" id="endTime" name="p_end_time" value="<%= data.p_end_time || '' %>" step="60">
                    </div>
                    <div class="col-12 col-md-4">
                        <label class="form-label"><i class="fas fa-hourglass-half"></i> Process Time (HH:MM) <span class="badge-auto"><i class="fas fa-sync-alt"></i> Auto</span></label>
                        <input type="text" class="form-control process-time-field bg-light-readonly" id="processTimeDisplay" readonly placeholder="Auto from start/end">
                        <input type="hidden" id="processTimeHidden" name="p_process_time" value="<%= data.p_process_time || '' %>">
                        <small class="text-muted-info"><i class="fas fa-clock"></i> Calculated automatically</small>
                    </div>

                    <div class="col-12"><hr></div>

                    <!-- Machine Undermaintenance Time (minutes) -->
                    <div class="col-12 col-md-6">
                        <label class="form-label"><i class="fas fa-microchip"></i> Machine Undermaintenance Time (min)</label>
                        <input type="number" step="any" class="form-control" name="p_m_processtime" id="maintenanceTime" value="<%= data.p_m_processtime || '' %>" placeholder="e.g., 15.5 min">
                    </div>

                    <!-- Machine Undermaintenance Reason -->
                    <div class="col-12 col-md-6">
                        <label class="form-label"><i class="fas fa-tools"></i> Machine Undermaintenance Reason</label>
                        <select class="form-select" name="p_mureason" id="muReasonSelect">
                            <option value="">-- Select Reason --</option>
                            <option value="Mechanical Issue" <%= data.p_mureason === 'Mechanical Issue' ? 'selected' : '' %>>🔧 Mechanical Issue</option>
                            <option value="Electrical fault" <%= data.p_mureason === 'Electrical fault' ? 'selected' : '' %>>⚡ Electrical fault</option>
                            <option value="Material Shortage" <%= data.p_mureason === 'Material Shortage' ? 'selected' : '' %>>📦 Material Shortage</option>
                            <option value="Power Interruption" <%= data.p_mureason === 'Power Interruption' ? 'selected' : '' %>>🔌 Power Interruption</option>
                            <option value="Sanctioned Break" <%= data.p_mureason === 'Sanctioned Break' ? 'selected' : '' %>>☕ Sanctioned Break</option>
                            <option value="Line Changeover" <%= data.p_mureason === 'Line Changeover' ? 'selected' : '' %>>🔄 Line Changeover</option>
                            <option value="Other/Unclassified" <%= data.p_mureason === 'Other/Unclassified' ? 'selected' : '' %>>❓ Other/Unclassified</option>
                        </select>
                        <div id="otherReasonWrapper" style="display: none; margin-top: 10px;">
                            <input type="text" class="form-control" name="other_gmr" id="otherReasonInput" placeholder="Please specify reason" value="<%= data.other_gmr || '' %>">
                            <small class="text-muted-info"><i class="fas fa-pen"></i> Provide detailed reason</small>
                        </div>
                    </div>

                    <!-- Justification & Corrective Action -->
                    <div class="col-12 col-md-6">
                        <label class="form-label"><i class="fas fa-clipboard-list"></i> Justification & Corrective Action</label>
                        <input type="text" class="form-control" name="p_mjustification" id="justification" value="<%= data.p_mjustification || '' %>" placeholder="Action taken / comments">
                    </div>

                    <!-- Rejection Quantity -->
                    <div class="col-12 col-md-6">
                        <label class="form-label"><i class="fas fa-times-circle"></i> Rejection Quantity</label>
                        <input type="text" class="form-control" name="p_rejectionqty" id="rejectionQty" value="<%= data.p_rejectionqty || '' %>" placeholder="Number of rejected parts">
                    </div>

                    <!-- Action Buttons -->
                    <div class="col-12 mt-4">
                        <div class="action-buttons">
                            <button type="submit" class="btn btn-update text-white" id="updateBtn">
                                <i class="fas fa-save"></i> Update Record
                            </button>

                            <% if(orole == "admin"){ %>
                                <a href="/admin_punching_dashboard" class="btn-back-outline">
                                    <i class="fas fa-arrow-left"></i> Back to Records
                                </a>
                            <% }else{ %>
                                <a href="/punchingproductionrecord" class="btn-back-outline">
                                    <i class="fas fa-arrow-left"></i> Back to Records
                                </a>
                            <% } %>
                        </div>
                        <small class="text-muted-info d-block mt-3 text-center">
                            <i class="fas fa-shield-alt"></i> Review changes — weight & process time (start/end) auto-calculated.
                        </small>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    (function() {
        // Density mapping (g/cm³)
        const materialDensityMap = {
            "MS": 7.85,
            "ALUMINIUM": 2.70,
            "SS": 7.93,
            "GI": 7.85,
            "HRPO": 7.85,
            "PERFORATED": 7.85
        };

        function getSelectedDensity() {
            let materialSelect = document.getElementById('materialSelect');
            let selectedMaterial = materialSelect ? materialSelect.value : 'MS';
            return materialDensityMap[selectedMaterial] || 7.85;
        }

        // Weight calculation (kg)
        function calculateTotalWeight() {
            let length = parseFloat(document.getElementById('length')?.value) || 0;
            let width = parseFloat(document.getElementById('width')?.value) || 0;
            let thickness = parseFloat(document.getElementById('thickness')?.value) || 0;
            let qty = parseFloat(document.getElementById('sheetQty')?.value) || 0;
            let density = getSelectedDensity();
            let weight = (length * width * thickness * qty * density) / 1000000;
            if (isNaN(weight) || weight < 0) weight = 0;
            let weightField = document.getElementById('totalWeight');
            if (weightField) {
                weightField.value = weight.toFixed(3) + " Kg";
            }
        }

        // Process Time calculation (HH:MM) from startTime and endTime
        function calculateProcessTime() {
            const startInput = document.getElementById('startTime');
            const endInput = document.getElementById('endTime');
            const displayField = document.getElementById('processTimeDisplay');
            const hiddenField = document.getElementById('processTimeHidden');
            
            if (!startInput || !endInput) return;
            
            const startVal = startInput.value;
            const endVal = endInput.value;
            
            if (!startVal || !endVal) {
                if (displayField) displayField.value = '';
                // Don't clear hidden field if it has existing DB value
                return;
            }
            
            const [startHour, startMin] = startVal.split(':').map(Number);
            const [endHour, endMin] = endVal.split(':').map(Number);
            let startTotal = startHour * 60 + startMin;
            let endTotal = endHour * 60 + endMin;
            let diffMinutes = endTotal - startTotal;
            if (diffMinutes < 0) diffMinutes += 24 * 60;
            
            const hours = Math.floor(diffMinutes / 60);
            const minutes = diffMinutes % 60;
            const formatted = `${hours.toString().padStart(2, '0')}:${minutes.toString().padStart(2, '0')}`;
            if (displayField) displayField.value = formatted;
            if (hiddenField) hiddenField.value = formatted;
        }

        // attach event listeners for weight
        const calcElements = document.querySelectorAll('.calculate');
        calcElements.forEach(el => {
            el.addEventListener('input', calculateTotalWeight);
            el.addEventListener('change', calculateTotalWeight);
        });
        const materialSelect = document.getElementById('materialSelect');
        if (materialSelect) materialSelect.addEventListener('change', calculateTotalWeight);
        
        // attach process time listeners
        const startTimeEl = document.getElementById('startTime');
        const endTimeEl = document.getElementById('endTime');
        if (startTimeEl && endTimeEl) {
            startTimeEl.addEventListener('input', calculateProcessTime);
            endTimeEl.addEventListener('input', calculateProcessTime);
            startTimeEl.addEventListener('change', calculateProcessTime);
            endTimeEl.addEventListener('change', calculateProcessTime);
        }
        
        // initial calculations
        calculateTotalWeight();
        calculateProcessTime();
        
        // ----- Other reason dynamic for Undermaintenance reason
        const muReasonSelect = document.getElementById('muReasonSelect');
        const otherWrapper = document.getElementById('otherReasonWrapper');
        const otherReasonInput = document.getElementById('otherReasonInput');
        
        function toggleOtherReason() {
            if (muReasonSelect && otherWrapper) {
                if (muReasonSelect.value === 'Other/Unclassified') {
                    otherWrapper.style.display = 'block';
                    if (otherReasonInput) otherReasonInput.required = true;
                } else {
                    otherWrapper.style.display = 'none';
                    if (otherReasonInput) {
                        otherReasonInput.required = false;
                    }
                }
            }
        }
        if (muReasonSelect) {
            muReasonSelect.addEventListener('change', toggleOtherReason);
            toggleOtherReason();
        }
        
        // Form submission validation
        const updateForm = document.getElementById('updateForm');
        if (updateForm) {
            updateForm.addEventListener('submit', function(e) {
                let materialVal = document.getElementById('materialSelect')?.value;
                if (!materialVal) {
                    alert("❌ Material is required. Please select a material.");
                    e.preventDefault();
                    return false;
                }
                
                let customerVal = document.getElementById('customerSelect')?.value;
                if (!customerVal) {
                    alert("❌ Customer is required. Please select a customer.");
                    e.preventDefault();
                    return false;
                }
                
                let projectVal = document.getElementById('projectName')?.value;
                if (!projectVal || projectVal.trim() === "") {
                    alert("❌ Project Name is required.");
                    e.preventDefault();
                    return false;
                }
                
                // Ensure process time is calculated if times exist
                if (startTimeEl?.value && endTimeEl?.value) {
                    calculateProcessTime();
                }
                
                // Validate other reason
                if (muReasonSelect && muReasonSelect.value === 'Other/Unclassified') {
                    if (!otherReasonInput || !otherReasonInput.value.trim()) {
                        alert("⚠️ Please specify a reason for 'Other/Unclassified' maintenance category.");
                        e.preventDefault();
                        return false;
                    }
                }
                
                let confirmUpdate = confirm("⚠️ Confirm update: This will permanently modify the production record. Continue?");
                if (!confirmUpdate) {
                    e.preventDefault();
                }
            });
        }
        
        // sanitize numeric fields
        const numericInputs = document.querySelectorAll('input[type="number"]');
        numericInputs.forEach(inp => {
            inp.addEventListener('blur', function() {
                if (this.value && parseFloat(this.value) < 0) this.value = 0;
                if (this.id === 'sheetQty' || this.id === 'length' || this.id === 'width' || this.id === 'thickness') {
                    calculateTotalWeight();
                }
            });
        });
        
        // Prefill display if hidden has value and start/end empty
        const existingProcess = document.getElementById('processTimeHidden')?.value;
        const displayField = document.getElementById('processTimeDisplay');
        if (existingProcess && displayField && !displayField.value && (!startTimeEl?.value || !endTimeEl?.value)) {
            displayField.value = existingProcess;
        }
        
        console.log("✅ Edit form ready: weight + process time (start/end) auto-calculation active");
    })();
</script>
</body>
</html>