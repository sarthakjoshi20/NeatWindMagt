<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>NeatWind | Staff Login</title>

    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- Google Fonts + Font Awesome -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, #0a2a3b 0%, #1a4a6e 50%, #0d3550 100%);
            min-height: 100vh;
        }

        .navbar-custom {
            background: linear-gradient(115deg, #1e3c72 0%, #2a5298 100%);
            padding: 0.5rem 1.5rem;
            box-shadow: 0 12px 28px -8px rgba(0, 0, 0, 0.25);
        }

        .navbar-brand {
            font-weight: 700;
            font-size: 1.6rem;
            letter-spacing: -0.3px;
            color: white !important;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .navbar-brand i {
            font-size: 1.8rem;
            color: #f9c74f;
        }

        .nav-link-custom {
            color: rgba(255, 255, 255, 0.92) !important;
            font-weight: 600;
            padding: 0.5rem 1.2rem !important;
            border-radius: 50px;
            transition: all 0.25s ease;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .nav-link-custom:hover {
            background: rgba(255, 255, 255, 0.18);
        }

        .main-content {
            min-height: calc(100vh - 76px);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem 1.5rem;
        }

        .login-container {
            max-width: 480px;
            width: 100%;
        }

        .login-card {
            background: white;
            border-radius: 2rem;
            padding: 2.5rem 2rem;
            box-shadow: 0 25px 45px -12px rgba(0, 0, 0, 0.35);
            border-bottom: 4px solid #2f855a;
        }

        .role-icon {
            width: 85px;
            height: 85px;
            background: linear-gradient(145deg, #e6f7ec, #d9f0e2);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1.2rem auto;
            font-size: 2.8rem;
            color: #2b6e3c;
        }

        h3 {
            font-size: 1.8rem;
            font-weight: 800;
            text-align: center;
            color: #2b6e3c;
            margin-bottom: 0.25rem;
        }

        .role-badge {
            text-align: center;
            background: rgba(0,0,0,0.04);
            padding: 0.35rem 1rem;
            border-radius: 40px;
            font-size: 0.8rem;
            font-weight: 600;
            color: #4a5568;
            margin: 0.5rem 0 1.8rem 0;
        }

        .form-group {
            margin-bottom: 1.3rem;
        }

        .form-label {
            font-weight: 600;
            color: #1f2937;
            margin-bottom: 0.5rem;
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 0.9rem;
        }

        .form-control {
            width: 100%;
            padding: 0.75rem 1rem;
            border-radius: 60px;
            border: 1.5px solid #e2e8f0;
            font-weight: 500;
            transition: all 0.2s;
        }

        .form-control:focus {
            border-color: #2f855a;
            outline: none;
            box-shadow: 0 0 0 3px rgba(47,133,90,0.2);
        }

        .btn-login {
            width: 100%;
            padding: 0.85rem;
            border-radius: 60px;
            font-weight: 700;
            font-size: 1rem;
            border: none;
            margin-top: 0.5rem;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            background: linear-gradient(95deg, #2c5a2e, #1e4a2f);
            color: white;
        }

        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 18px -6px rgba(0,0,0,0.25);
        }

        .dashboard-footer {
            text-align: center;
            margin-top: 2rem;
            font-size: 0.75rem;
            color: rgba(255,255,240,0.7);
        }

        @media (max-width: 560px) {
            .login-card { padding: 1.8rem; }
            h3 { font-size: 1.5rem; }
            .role-icon { width: 70px; height: 70px; font-size: 2.2rem; }
        }
    </style>
</head>
<body>

<nav class="navbar navbar-expand-lg navbar-custom">
    <div class="container-fluid">
        <a class="navbar-brand" href="/">
            <i class="fas fa-industry"></i> NeatWind
        </a>
        <div>
            <a class="nav-link-custom" href="/" >
                <i class="fas fa-arrow-right-from-bracket"></i> Dashboard
            </a>
        </div>
    </div>
</nav>

<div class="main-content">
    <div class="login-container">
        <div class="login-card">
            <div class="role-badge">
                <h3>Department Login</h3>
                <i class="fas fa-id-card"></i> Department Access
            </div>

            <form id="staffLoginForm" action="/checkauthuser" method="POST">
                <input type="hidden" name="form_type" value="user_login">
                <div class="form-group">
                    <label class="form-label">
                        <i class="fas fa-user"></i> Username
                    </label>
                    <input type="text" class="form-control" name="username" placeholder="Enter your username" required autocomplete="off">
                </div>
                <div class="form-group">
                    <label class="form-label">
                        <i class="fas fa-lock"></i> Password
                    </label>
                    <input type="password" class="form-control" name="password" placeholder="Enter your password" required>
                </div>
                <button type="submit" class="btn-login">
                    <i class="fas fa-arrow-right-to-bracket"></i> Access Dashboard
                </button>
            </form>
        </div>

        <div class="dashboard-footer">
            <i class="fas fa-lock"></i> Authorized access only<br>
            <span id="currentTime"></span>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<script>
    (function() {
        const exitBtn = document.getElementById('exitBtn');
        const loginForm = document.getElementById('staffLoginForm');

        if (exitBtn) {
            exitBtn.addEventListener('click', (e) => {
                e.preventDefault();
                if (confirm("Exit department portal?")) {
                    window.location.reload("/");
                }
            });
        }

        // Live timestamp
        function updateTime() {
            const timeSpan = document.getElementById('currentTime');
            if (timeSpan) {
                const now = new Date();
                timeSpan.innerHTML = `<i class="far fa-clock"></i> ${now.toLocaleTimeString()}`;
            }
        }
        updateTime();
        setInterval(updateTime, 1000);

        // Prevent double submission
        let isSubmitting = false;
        if (loginForm) {
            loginForm.addEventListener('submit', function(e) {
                if (isSubmitting) {
                    e.preventDefault();
                    return false;
                }
                isSubmitting = true;
                const submitBtn = this.querySelector('.btn-login');
                if (submitBtn) {
                    submitBtn.disabled = true;
                    submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Authenticating...';
                }
                setTimeout(() => { isSubmitting = false; }, 8000);
            });
        }
    })();
</script>
</body>
</html>